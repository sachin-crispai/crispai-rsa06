<header>
  <h1>🗺 RSA 2026 — CrispAI Floor Map</h1>
  <span>Moscone Center · March 23-26 · Generated {now}</span>
  <input id="search" type="text" placeholder="Search vendor, cluster, booth…" oninput="filterVendors(this.value)">
</header>

<div id="hall-tabs"></div>

<div id="main">
  <div id="map-wrap">
    <img id="map-img" src="" alt="" style="display:none">
    <svg id="schematic-bg" xmlns="http://www.w3.org/2000/svg"></svg>
    <div id="pins"></div>
    <div id="stats"></div>
    <div id="legend">
      <div id="legend-toggle" onclick="toggleLegend()">🎨 Legend ▾</div>
      <div id="legend-items"></div>
    </div>
  </div>

  <div id="sidebar">
    <div id="vendor-count"></div>
    <div id="vendor-list"></div>
  </div>
