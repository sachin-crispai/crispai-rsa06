#!/usr/bin/env python3
"""
Build-Map — CrispAI RSA 2026
Generates a self-contained interactive HTML floor map of RSA 2026.

Reads docs/maps/booth-index.json (vendor locations) and produces
docs/maps/index.html — a single offline file with:
  • Hall-by-hall floor plan views (image or schematic)
  • Clickable vendor pins color-coded by cluster
  • Sidebar with vendor info + direct link to redbook.md
  • Search/filter by name, cluster, hall
  • Visit status overlay (⬜ / ✅) from redbook Visit Log

Usage:
    ./scripts/build-map                    # generate map from booth-index.json
    ./scripts/build-map --open             # generate and open in browser
"""

import argparse
import json
import re
import subprocess
import sys
from pathlib import Path

REPO_ROOT   = Path(__file__).parent.parent
DOCS_DIR    = REPO_ROOT / "docs"
MAPS_DIR    = DOCS_DIR / "maps"
VENDORS_DIR = DOCS_DIR / "vendors"
CLUSTERS_DIR = DOCS_DIR / "clusters"

# Cluster → colour mapping (matches the 24 cluster scheme)
CLUSTER_COLORS = {
    "AI / ML Security":               "#e74c3c",
    "Endpoint Security / EDR":        "#3498db",
    "Cloud Security / CNAPP":         "#2ecc71",
    "Identity & Access Management":   "#9b59b6",
    "Network Security / NDR":         "#1abc9c",
    "AppSec / DevSecOps":             "#f39c12",
    "OT / ICS / IoT Security":        "#e67e22",
    "Data Security":                  "#27ae60",
    "Threat Intelligence":            "#c0392b",
    "Zero Trust / SASE":              "#2980b9",
    "Managed Security / MSSP":        "#8e44ad",
    "GRC / Risk / Compliance":        "#16a085",
    "Security Awareness & Training":  "#d35400",
    "API Security":                   "#f1c40f",
    "SIEM / SOAR / XDR":             "#7f8c8d",
    "Email Security":                 "#95a5a6",
    "Deception":                      "#c0392b",
    "Fraud Prevention":               "#2c3e50",
    "PAM / Secrets":                  "#8e44ad",
    "DSPM / Data Privacy":            "#27ae60",
    "Vulnerability Management":       "#e74c3c",
    "Backup / Recovery":              "#3498db",
    "Default":                        "#7f8c8d",
}

HALL_ORDER = [
    ("North Hall",      "N"),
    ("South Hall",      "S"),
    ("West Hall L1",    "WL1"),
    ("West Hall L2",    "WL2"),
    ("Early Stage Expo","ESE"),
    ("Innovation Sandbox","IS"),
]

# Schematic layout parameters per hall
# Maps booth number prefix ranges to approximate grid positions
BOOTH_LAYOUT = {
    "N": {"cols": 22, "rows": 14, "start": 5700, "step": 100},
    "S": {"cols": 22, "rows": 14, "start": 600,  "step": 100},
    "W": {"cols": 10, "rows": 12, "start": 100,  "step": 100},
}


# ── Load vendor data ───────────────────────────────────────────────────────────

def load_vendors() -> list[dict]:
    idx = MAPS_DIR / "booth-index.json"
    if idx.exists():
        return json.loads(idx.read_text())

    # Fallback: build from redbooks directly
    vendors = []
    for rb in sorted(VENDORS_DIR.glob("*/redbook.md")):
        slug = rb.parent.name
        if slug == "_template":
            continue
        text = rb.read_text()

        name_m    = re.search(r"^# (.+?) —", text, re.M)
        booth_m   = re.search(r"\*\*Booth\*\*\s*\|\s*(.+?)\s*\|", text)
        hall_m    = re.search(r"\*\*Hall\*\*\s*\|\s*(.+?)\s*\|", text)
        tier_m    = re.search(r"\*\*Sponsor Tier\*\*\s*\|\s*(.+?)\s*\|", text)
        attend_m  = re.search(r"\*\*Attendance\*\*\s*\|\s*(.+?)\s*\|", text)
        nav_m     = re.search(r"\*\*Navigate\*\*\s*\|\s*(.+?)\s*\|", text)
        cluster_m = re.search(r"\*\*Cluster:\*\*\s*(.+)", text)
        visited_m = re.search(r"\*\*Status\*\*\s*\|\s*(.+?)\s*\|", text)
        brief_lines = re.findall(r"^\d+\. (.+)$", text, re.M)

        attend = attend_m.group(1).strip() if attend_m else ""
        if "Not Attending" in attend:
            continue

        booth = booth_m.group(1).strip() if booth_m else "?"
        if booth in ("Not Found", "—", ""):
            booth = "?"

        vendors.append({
            "slug":    slug,
            "name":    name_m.group(1).strip() if name_m else slug,
            "booth":   booth,
            "hall":    hall_m.group(1).strip()    if hall_m    else "?",
            "tier":    tier_m.group(1).strip()    if tier_m    else "?",
            "attend":  attend,
            "nav":     nav_m.group(1).strip()     if nav_m     else "",
            "cluster": cluster_m.group(1).strip() if cluster_m else "Default",
            "visited": visited_m.group(1).strip() if visited_m else "",
            "brief":   brief_lines[:3],
            "redbook": f"../vendors/{slug}/redbook.md",
            "x_pct":   None,
            "y_pct":   None,
        })

    return vendors


# ── Assign schematic coordinates ──────────────────────────────────────────────

def assign_schematic_coords(vendors: list[dict]) -> list[dict]:
    """
    Assign (x_pct, y_pct) based on booth number when real coords are absent.
    Uses a serpentine grid model matching typical trade show aisle patterns.
    """
    # Group by hall prefix
    from collections import defaultdict
    by_hall: dict[str, list] = defaultdict(list)

    for v in vendors:
        booth = v.get("booth", "?")
        if booth == "?":
            continue
        # Extract prefix and number
        m = re.match(r"([A-Z]+)-?(\d+)", booth.upper())
        if m:
            prefix = m.group(1)
            number = int(m.group(2))
            by_hall[prefix].append((number, v))

    for prefix, items in by_hall.items():
        items.sort(key=lambda x: x[0])
        n = len(items)
        params = BOOTH_LAYOUT.get(prefix, {"cols": 12, "rows": 10})
        cols = params["cols"]

        for i, (num, v) in enumerate(items):
            col = i % cols
            row = i // cols
            total_rows = max(1, (n + cols - 1) // cols)

            # 5–95% range with padding
            x = 5 + (col / max(cols - 1, 1)) * 90
            y = 5 + (row / max(total_rows - 1, 1)) * 90

            # Serpentine: alternate row direction
            if row % 2 == 1:
                x = 95 - (x - 5)

            v["x_pct"] = round(x, 1)
            v["y_pct"] = round(y, 1)

    # Vendors with no booth get parked at 50,50 (shown differently)
    for v in vendors:
        if v.get("x_pct") is None:
            v["x_pct"] = 50.0
            v["y_pct"] = 50.0
            v["no_coords"] = True

    return vendors


# ── Check for hall floor plan images ──────────────────────────────────────────

def get_hall_images() -> dict[str, str]:
    """Return base64-encoded images per hall slug, if available."""
    import base64
    images = {}
    slugs = {
        "North Hall":       "north-hall",
        "South Hall":       "south-hall",
        "West Hall L1":     "west-hall-l1",
        "West Hall L2":     "west-hall-l2",
        "Early Stage Expo": "ese",
    }
    for hall, slug in slugs.items():
        for ext in ("png", "jpg", "jpeg"):
            f = MAPS_DIR / f"{slug}.{ext}"
            if f.exists():
                b64 = base64.b64encode(f.read_bytes()).decode()
                images[hall] = f"data:image/{ext};base64,{b64}"
                break
    return images


# ── Generate HTML ──────────────────────────────────────────────────────────────

def generate_html(vendors: list[dict]) -> str:
    hall_images = get_hall_images()

    # Deduplicate cluster colours
    clusters = sorted({v.get("cluster", "Default") for v in vendors})
    color_js = json.dumps({c: CLUSTER_COLORS.get(c, CLUSTER_COLORS["Default"])
                            for c in clusters})

    vendors_js = json.dumps(vendors, ensure_ascii=False)
    hall_images_js = json.dumps(hall_images)

    now = __import__("datetime").datetime.now().strftime("%Y-%m-%d %H:%M")

    return f"""<!DOCTYPE html>
