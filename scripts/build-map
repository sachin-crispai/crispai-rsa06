<script>
const VENDORS = {vendors_js};
const CLUSTER_COLORS = {color_js};
const HALL_IMAGES = {hall_images_js};

const HALLS = ["North Hall","South Hall","West Hall L1","West Hall L2","Early Stage Expo","Innovation Sandbox"];

let currentHall = null;
let selectedVendor = null;
let filterText = "";

// ── Init ──────────────────────────────────────────────────────────────────────

function init() {{
  buildHallTabs();
  buildLegend();

  // Default to first hall with vendors
  const halls = getHallsWithVendors();
  selectHall(halls[0] || "North Hall");
}}

function getHallsWithVendors() {{
  const s = new Set(VENDORS.map(v => v.hall));
  return HALLS.filter(h => s.has(h));
}}

// ── Hall tabs ─────────────────────────────────────────────────────────────────

function buildHallTabs() {{
  const hallsWithVendors = getHallsWithVendors();
  const container = document.getElementById("hall-tabs");
  container.innerHTML = "";

  // "All" tab
  const allTab = document.createElement("button");
  allTab.className = "tab";
  allTab.textContent = `All (${{VENDORS.length}})`;
  allTab.onclick = () => selectHall("All");
  container.appendChild(allTab);

  for (const hall of hallsWithVendors) {{
    const count = VENDORS.filter(v => v.hall === hall).length;
    const tab = document.createElement("button");
    tab.className = "tab";
    tab.id = `tab-${{hall.replace(/\\s+/g,"-")}}`;
    tab.textContent = `${{hall}} (${{count}})`;
    tab.onclick = () => selectHall(hall);
    container.appendChild(tab);
  }}
}}

function selectHall(hall) {{
  currentHall = hall;
  document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
  const id = `tab-${{hall.replace(/\\s+/g,"-")}}`;
  const t = document.getElementById(id) || document.querySelector(".tab");
  if (t) t.classList.add("active");

  renderMap();
  renderSidebar();
}}

// ── Map rendering ─────────────────────────────────────────────────────────────

function renderMap() {{
  const mapImg  = document.getElementById("map-img");
  const pinsDiv = document.getElementById("pins");
  const svgBg   = document.getElementById("schematic-bg");

  // Show background image if available
  const img = HALL_IMAGES[currentHall];
  if (img) {{
    mapImg.src = img;
    mapImg.style.display = "block";
    svgBg.innerHTML = "";
  }} else {{
    mapImg.style.display = "none";
    drawSchematicGrid(svgBg);
  }}

  // Filter vendors for this hall
  const visible = getVisibleVendors();
  pinsDiv.innerHTML = "";

  for (const v of visible) {{
    if (v.x_pct == null) continue;
    const pin = document.createElement("div");
    pin.className = "pin";
    pin.style.left = v.x_pct + "%";
    pin.style.top  = v.y_pct + "%";

    const color = CLUSTER_COLORS[v.cluster] || CLUSTER_COLORS["Default"] || "#718096";
    const visited = v.visited && v.visited.includes("✅");

    pin.innerHTML = `
      <div class="pin-dot" style="background:${{color}};${{visited ? 'opacity:0.5' : ''}}"></div>
      <div class="pin-label">${{v.booth}} ${{v.name.split(" ")[0]}}</div>
    `;
    pin.title = `${{v.name}} — ${{v.booth}}`;
    pin.dataset.slug = v.slug;
    pin.onclick = () => selectVendor(v.slug);
    pinsDiv.appendChild(pin);
  }}

  updateStats(visible);
}}

function drawSchematicGrid(svg) {{
  const w = svg.parentElement.offsetWidth || 800;
  const h = svg.parentElement.offsetHeight || 600;
  svg.setAttribute("viewBox", `0 0 ${{w}} ${{h}}`);

  // Hall outline
  const rect = document.createElementNS("http://www.w3.org/2000/svg","rect");
  rect.setAttribute("x","20"); rect.setAttribute("y","20");
  rect.setAttribute("width", w-40); rect.setAttribute("height", h-40);
  rect.setAttribute("fill","none"); rect.setAttribute("stroke","#2d3748");
  rect.setAttribute("stroke-width","2"); rect.setAttribute("rx","4");
  svg.appendChild(rect);

  // Hall label
  const text = document.createElementNS("http://www.w3.org/2000/svg","text");
  text.setAttribute("x", w/2); text.setAttribute("y", 14);
  text.setAttribute("text-anchor","middle"); text.setAttribute("fill","#4a5568");
  text.setAttribute("font-size","12"); text.setAttribute("font-family","sans-serif");
  text.textContent = currentHall === "All" ? "All Halls — Schematic" : `${{currentHall}} — Schematic Layout`;
  svg.appendChild(text);

  // Aisle lines (every 10%)
  for (let pct = 20; pct <= 80; pct += 20) {{
    const line = document.createElementNS("http://www.w3.org/2000/svg","line");
    const x = 20 + ((w-40) * pct/100);
    line.setAttribute("x1", x); line.setAttribute("y1", 20);
    line.setAttribute("x2", x); line.setAttribute("y2", h-20);
    line.setAttribute("stroke","#2d3748"); line.setAttribute("stroke-width","0.5");
    line.setAttribute("stroke-dasharray","4,4");
    svg.appendChild(line);
  }}
}}

// ── Sidebar ───────────────────────────────────────────────────────────────────

function renderSidebar() {{
  const list = document.getElementById("vendor-list");
  const visible = getVisibleVendors(true); // include filtered
  list.innerHTML = "";

  document.getElementById("vendor-count").textContent =
    `${{visible.length}} vendors${{currentHall !== "All" ? " in " + currentHall : ""}}`;

  for (const v of visible) {{
    const color = CLUSTER_COLORS[v.cluster] || "#718096";
    const visited = v.visited && v.visited.includes("✅");
    const brief = v.brief && v.brief[0] ? v.brief[0] : "";

    const card = document.createElement("div");
    card.className = "vendor-card";
    card.dataset.slug = v.slug;
    card.innerHTML = `
      <div class="vc-header">
        <div class="vc-dot" style="background:${{color}}"></div>
        <div class="vc-name">${{v.name}}</div>
        <div class="vc-booth">${{v.booth}}</div>
        ${{visited ? '<span class="visited-badge">✅</span>' : ''}}
      </div>
      <div class="vc-meta">${{v.hall}} ${{v.tier !== "❓ Unknown" ? "· " + v.tier : ""}}</div>
      <div class="vc-cluster" style="background:${{color}}22;color:${{color}}">${{v.cluster}}</div>
      ${{brief ? `<div class="vc-brief">${{brief}}</div>` : ""}}
      <div class="vc-links">
        <a href="${{v.redbook}}" target="_blank">📋 Redbook</a>
        ${{v.nav && v.nav !== "—" ? `<a href="#" onclick="showNav('${{v.slug}}');return false">🗺 Navigate</a>` : ""}}
      </div>
    `;
    card.onclick = (e) => {{ if (!e.target.closest("a")) selectVendor(v.slug); }};
    list.appendChild(card);
  }}
}}

// ── Filter ────────────────────────────────────────────────────────────────────

function filterVendors(text) {{
  filterText = text.toLowerCase();
  renderMap();
  renderSidebar();
}}

function getVisibleVendors(forSidebar=false) {{
  let vendors = VENDORS;

  // Hall filter (for map pins, always filter by hall; sidebar shows all if "All")
  if (currentHall !== "All") {{
    vendors = vendors.filter(v => v.hall === currentHall);
  }}

  // Text filter
  if (filterText) {{
    vendors = vendors.filter(v =>
      v.name.toLowerCase().includes(filterText) ||
      v.booth.toLowerCase().includes(filterText) ||
      (v.cluster || "").toLowerCase().includes(filterText) ||
      (v.hall || "").toLowerCase().includes(filterText)
    );
  }}

  return vendors;
}}

// ── Vendor selection ──────────────────────────────────────────────────────────

function selectVendor(slug) {{
  selectedVendor = slug;

  // Highlight pin
  document.querySelectorAll(".pin").forEach(p => {{
    p.classList.toggle("selected", p.dataset.slug === slug);
  }});

  // Highlight sidebar card
  document.querySelectorAll(".vendor-card").forEach(c => {{
    c.classList.toggle("selected", c.dataset.slug === slug);
    if (c.dataset.slug === slug) c.scrollIntoView({{block:"nearest"}});
  }});

  const v = VENDORS.find(x => x.slug === slug);
  if (v) showDetailPanel(v);
}}

function showDetailPanel(v) {{
  const color = CLUSTER_COLORS[v.cluster] || "#718096";
  const dp = document.getElementById("detail-panel");
  const dc = document.getElementById("dp-content");

  const briefHtml = v.brief && v.brief.length
    ? "<p style='font-size:12px;color:#a0aec0;margin-top:8px'>" + v.brief.join("<br>") + "</p>"
    : "";

  dc.innerHTML = `
    <h2>${{v.name}}</h2>
    <div style="font-size:11px;margin-bottom:8px">
      <span style="background:${{color}}22;color:${{color}};padding:2px 8px;border-radius:10px">${{v.cluster}}</span>
    </div>
    <table>
      <tr><td>Booth</td><td><strong>${{v.booth}}</strong></td></tr>
      <tr><td>Hall</td><td>${{v.hall}}</td></tr>
      <tr><td>Tier</td><td>${{v.tier}}</td></tr>
      <tr><td>Status</td><td>${{v.visited || "⬜ Not visited"}}</td></tr>
      ${{v.nav && v.nav !== "—" ? `<tr><td>Navigate</td><td style='font-size:10px'>${{v.nav}}</td></tr>` : ""}}
    </table>
    ${{briefHtml}}
    <div id="dp-links">
      <a href="${{v.redbook}}" target="_blank">📋 Open Redbook</a>
    </div>
  `;
  dp.classList.add("visible");
}}

function closeDetail() {{
  document.getElementById("detail-panel").classList.remove("visible");
  selectedVendor = null;
  document.querySelectorAll(".pin").forEach(p => p.classList.remove("selected"));
  document.querySelectorAll(".vendor-card").forEach(c => c.classList.remove("selected"));
}}

function showNav(slug) {{
  const v = VENDORS.find(x => x.slug === slug);
  if (v && v.nav) alert(v.name + " — Navigation:\\n\\n" + v.nav);
}}

// ── Legend ────────────────────────────────────────────────────────────────────

function buildLegend() {{
  const items = document.getElementById("legend-items");
  for (const [cluster, color] of Object.entries(CLUSTER_COLORS)) {{
    if (cluster === "Default") continue;
    const count = VENDORS.filter(v => v.cluster === cluster).length;
    if (count === 0) continue;
    const div = document.createElement("div");
    div.className = "leg-item";
    div.innerHTML = `<div class="leg-dot" style="background:${{color}}"></div>
      <span style="color:#a0aec0">${{cluster.split("/")[0].trim()}} (${{count}})</span>`;
    items.appendChild(div);
  }}
}}

function toggleLegend() {{
  document.getElementById("legend-items").classList.toggle("visible");
}}

function updateStats(visible) {{
  const confirmed = visible.filter(v => v.visited && v.visited.includes("✅")).length;
  document.getElementById("stats").textContent =
    `${{visible.length}} vendors · ${{confirmed}} visited`;
}}

// ── Keyboard nav ──────────────────────────────────────────────────────────────

document.addEventListener("keydown", e => {{
  if (e.key === "Escape") closeDetail();
  if (e.key === "/" && !e.ctrlKey) {{
    e.preventDefault();
    document.getElementById("search").focus();
  }}
}});

init();
</script>
</body>
</html>"""


# ── Main ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="Build-Map — generate RSA 2026 interactive floor map",
    )
    parser.add_argument("--open", "-o", action="store_true",
                        help="Open map in browser after generating")
    args = parser.parse_args()

    MAPS_DIR.mkdir(parents=True, exist_ok=True)

    print("Loading vendor data...")
    vendors = load_vendors()
    print(f"  {len(vendors)} attending vendors loaded")

    print("Assigning schematic coordinates for vendors without image coords...")
    vendors = assign_schematic_coords(vendors)
    with_coords = sum(1 for v in vendors if v.get("x_pct") is not None and not v.get("no_coords"))
    print(f"  {with_coords} vendors have coordinates")

    hall_images = get_hall_images()
    if hall_images:
        print(f"  Floor plan images found: {', '.join(hall_images.keys())}")
    else:
        print("  No floor plan images found — using schematic layout")
        print("  To add real maps: ./scripts/fetch-floorplan")

    print("Generating HTML map...")
    html = generate_html(vendors)

    out = MAPS_DIR / "index.html"
    out.write_text(html, encoding="utf-8")
    print(f"\n✅ Map saved: {out}")
    print(f"   {len(vendors)} vendor pins · {len(hall_images)} hall images")
    print(f"\nUsage:")
    print(f"   open {out}")
    print(f"   ./scripts/build-map --open")

    if args.open:
        import webbrowser
        webbrowser.open(f"file://{out.resolve()}")


if __name__ == "__main__":
    main()
