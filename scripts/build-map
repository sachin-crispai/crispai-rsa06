            border: 2px solid rgba(255,255,255,0.7); box-shadow: 0 2px 6px rgba(0,0,0,0.5); }}
.pin.selected .pin-dot {{ width: 16px; height: 16px; border-color: #fff;
                           box-shadow: 0 0 12px rgba(255,255,255,0.8); }}
.pin-label {{ position: absolute; top: -18px; left: 50%; transform: translateX(-50%);
              font-size: 9px; font-weight: 700; white-space: nowrap;
              background: rgba(0,0,0,0.75); padding: 1px 4px; border-radius: 3px;
              pointer-events: none; display: none; }}
.pin:hover .pin-label, .pin.selected .pin-label {{ display: block; }}

/* ── Sidebar ── */
#sidebar {{ width: 320px; flex-shrink: 0; background: #1a1f2e; overflow-y: auto;
            border-left: 1px solid #2d3748; }}
