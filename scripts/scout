#!/usr/bin/env python3
"""
Scout — CrispAI RSA 2026 Field Intelligence Agent (Text)
Ask questions about RSA vendors, clusters, and floor plan — no internet needed.
Powered by local Ollama (qwen2.5:32b) with compact redbook context.

Usage:
    ./scripts/scout "Which booths are in the North Hall?"
    ./scripts/scout "Compare CrowdStrike and SentinelOne"
    ./scripts/scout "What should I ask at the Wiz booth?"
    ./scripts/scout --chat    # interactive chat mode
"""

import argparse
import json
import sys
import os
from pathlib import Path

import urllib.request
import urllib.error

REPO_ROOT = Path(__file__).parent.parent
DOCS_DIR = REPO_ROOT / "docs"
OLLAMA_URL = "http://localhost:11434/api/generate"
TEXT_MODEL = "qwen2.5:32b"

SYSTEM_PROMPT = """You are CrispAI's RSA Conference 2026 field assistant.
RULE: Answer ONLY using facts from the KNOWLEDGE BASE below. Do NOT invent vendor names, booth numbers, or data not present. If unknown, say so.
Be concise and actionable. Always include real booth numbers when listing vendors."""


def load_redbook_context() -> str:
    """Load compact context: booth table + vendor index. ~2K tokens."""
    parts = []

    # Booth table from the redbook
    redbook = DOCS_DIR / "redbook" / "rsa_redbook.md"
    if redbook.exists():
        raw = redbook.read_text().splitlines()
        booth_section, in_booth = [], False
        for line in raw:
            if "Known Booth Locations" in line or "Booth Numbering" in line:
                in_booth = True
            if in_booth:
                booth_section.append(line)
                if len(booth_section) > 45:
                    break
        parts.append(
            "RSA 2026: March 23-26, Moscone Center, 747 Howard St SF\n"
            + "\n".join(booth_section)
        )

    # Compact vendor index: cluster|name|booth per line
    clusters_dir = DOCS_DIR / "clusters"
    if clusters_dir.exists():
        vendor_lines = []
        for f in sorted(clusters_dir.glob("*.md")):
            lines = f.read_text().splitlines()
            cluster = lines[0].replace("# Cluster ", "").replace("# ", "") if lines else f.stem
            tag = cluster.split("—")[-1].strip().split("(")[0].strip()[:12]
            for line in lines:
                if line.startswith("| **") and line.count("|") >= 4:
                    cols = [c.strip().replace("**", "") for c in line.split("|") if c.strip()]
                    if len(cols) >= 3:
                        booth = cols[2] if cols[2] not in ("—", "-", "") else "?"
                        vendor_lines.append(f"{tag}|{cols[0]}|{booth}")
        if vendor_lines:
            parts.append("VENDORS (cluster|name|booth):\n" + "\n".join(vendor_lines))

    return "\n\n".join(parts)


def ask_ollama(question: str, context: str, history: list = None) -> str:
    """Send question to Ollama with redbook context, streaming output."""
    history = history or []

    full_prompt = f"{SYSTEM_PROMPT}\n\nKNOWLEDGE BASE:\n{context}\n\n"
    for turn in history[-6:]:
        full_prompt += f"User: {turn['user']}\nAssistant: {turn['assistant']}\n\n"
    full_prompt += f"User: {question}\nAssistant:"

    payload = json.dumps({
        "model": TEXT_MODEL,
        "prompt": full_prompt,
        "stream": True,
        "options": {
            "temperature": 0.3,
            "num_predict": 1024,
            "num_ctx": 32768,
        }
    }).encode("utf-8")

    req = urllib.request.Request(
        OLLAMA_URL,
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST"
    )

    try:
        tokens = []
        with urllib.request.urlopen(req, timeout=600) as resp:
            for line in resp:
                line = line.strip()
                if not line:
                    continue
                chunk = json.loads(line.decode("utf-8"))
                token = chunk.get("response", "")
                tokens.append(token)
                print(token, end="", flush=True)
                if chunk.get("done"):
                    break
        print()
        return "".join(tokens).strip()
    except urllib.error.URLError:
        return "✗ Cannot reach Ollama. Start it with:\n  OLLAMA_FLASH_ATTENTION=1 /opt/homebrew/opt/ollama/bin/ollama serve"


def chat_mode(context: str):
    """Interactive multi-turn chat mode."""
    print("\nScout — CrispAI Field Intelligence Agent")
    print("Type 'exit' or Ctrl+C to quit\n")
    print("─" * 50)

    history = []
    while True:
        try:
            question = input("\nYou: ").strip()
        except (KeyboardInterrupt, EOFError):
            print("\nGoodbye!")
            break

        if not question:
            continue
        if question.lower() in {"exit", "quit", "bye"}:
            print("Goodbye!")
            break

        print("\nAssistant: ", end="", flush=True)
        answer = ask_ollama(question, context, history)
        history.append({"user": question, "assistant": answer})


def main():
    parser = argparse.ArgumentParser(
        description="Scout — CrispAI RSA 2026 field intelligence agent"
    )
    parser.add_argument("question", nargs="?",
                        help="Question to ask (omit for --chat mode)")
    parser.add_argument("--chat", "-c", action="store_true",
                        help="Interactive chat mode")
    parser.add_argument("--model", default=TEXT_MODEL,
                        help=f"Ollama text model (default: {TEXT_MODEL})")
    args = parser.parse_args()

    if not args.question and not args.chat:
        parser.print_help()
        print("\nExamples:")
        print('  ./scripts/scout "Which booths are in the North Hall?"')
        print('  ./scripts/scout "What should I ask at the Wiz booth?"')
        print('  ./scripts/scout "Compare CrowdStrike and SentinelOne"')
        print('  ./scripts/scout --chat')
        sys.exit(0)

    print("Loading redbook context...", end=" ", flush=True)
    context = load_redbook_context()
    print("ready\n", flush=True)

    if args.chat or not args.question:
        chat_mode(context)
    else:
        answer = ask_ollama(args.question, context)
        print(answer)


if __name__ == "__main__":
    main()
